# Backend connection used by the project-based clipping flow
MAIN_BACKEND_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000

# Optional site URL for auth callback routes if you keep Supabase enabled
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Supabase configuration
# The default open-source clipping flow does not require these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
